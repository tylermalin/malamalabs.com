# Copy to .env.local for `vercel dev` — never commit .env.local (see .gitignore).
# Set the same keys in the Vercel project → Settings → Environment Variables.

# Blockfrost (https://blockfrost.io) — preprod + mainnet project IDs
BLOCKFROST_PROJECT_ID_PREPROD=
BLOCKFROST_PROJECT_ID_MAINNET=

# Mālama wallet addresses for on-chain views (bech32)
MALAMA_ADDR_PREPROD=
MALAMA_ADDR_MAINNET=

# Optional: HTML page URL for field telemetry scrape (used by /api/live)
# SENSOR_PAGE_URL=

# ── Custom Hex Builder (admin) ───────────────────────────────────────────────

# Which geocoding provider to use: nominatim | google | mapbox
# GEOCODE_PROVIDER=nominatim

# H3 resolution (0-15). Resolution 9 ~= 0.1 km^2 hexagons (~ a city block).
# H3_RESOLUTION=9

# Sent as part of the Nominatim User-Agent per their usage policy — set to a
# real address before using this against real prospects.
# CONTACT_EMAIL=ops@malamalabs.com

# Required only if GEOCODE_PROVIDER=google
# GOOGLE_MAPS_API_KEY=

# Required only if GEOCODE_PROVIDER=mapbox
