# Copy to .env.local for `vercel dev` — never commit .env.local (see .gitignore).
# Set the same keys in the Vercel project → Settings → Environment Variables.

# Blockfrost (https://blockfrost.io) — preprod + mainnet project IDs
BLOCKFROST_PROJECT_ID_PREPROD=
BLOCKFROST_PROJECT_ID_MAINNET=

# Mālama wallet addresses for on-chain views (bech32)
MALAMA_ADDR_PREPROD=
MALAMA_ADDR_MAINNET=

# Optional: HTML page URL for field telemetry scrape (used by /api/live)
# SENSOR_PAGE_URL=
